// ============================================================
// CLARIM — Firestore Security Rules  v2.0
// Modelo: familyId isolation (compatível com plano familiar)
//
// COMO PUBLICAR:
//   console.firebase.google.com → Firestore Database → Regras
//   Cole este conteúdo e clique em "Publicar"
//
// MODELO DE SEGURANÇA:
//   • Cada usuário tem /users_profile/{uid} com campo "familyId".
//   • Por padrão familyId = uid (usuário solo).
//   • Plano familiar: basta que vários uids apontem para o MESMO
//     familyId — sem alterar uma linha destas regras.
//   • Nenhum usuário consegue ler ou gravar dados de outro familyId.
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Perfil de usuário ─────────────────────────────────────
    // Cada uid acessa somente o próprio documento.
    match /users_profile/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Funções auxiliares ────────────────────────────────────

    // Retorna true se o usuário está autenticado.
    function isAuth() {
      return request.auth != null;
    }

    // Lê o familyId do perfil do usuário logado.
    // Permite plano familiar: múltiplos uids → mesmo familyId.
    // O Firestore cacheia o get() por requisição — sem custo extra.
    function myFamilyId() {
      return get(/databases/$(database)/documents/users_profile/$(request.auth.uid))
               .data.familyId;
    }

    // Documento existente pertence ao familyId do usuário logado?
    function ownFamily() {
      return isAuth() && resource.data.familyId == myFamilyId();
    }

    // Payload gravado declara o familyId correto?
    function writingOwnFamily() {
      return isAuth() && request.resource.data.familyId == myFamilyId();
    }

    // ── Lançamentos (despesas) ────────────────────────────────
    match /lancamentos/{docId} {
      allow read:   if ownFamily();
      allow create: if writingOwnFamily();
      allow update: if ownFamily() && writingOwnFamily();
      allow delete: if ownFamily();
    }

    // ── Receitas ──────────────────────────────────────────────
    match /receitas/{docId} {
      allow read:   if ownFamily();
      allow create: if writingOwnFamily();
      allow update: if ownFamily() && writingOwnFamily();
      allow delete: if ownFamily();
    }

    // ── Cartões de crédito ────────────────────────────────────
    match /cartoes/{docId} {
      allow read:   if ownFamily();
      allow create: if writingOwnFamily();
      allow update: if ownFamily() && writingOwnFamily();
      allow delete: if ownFamily();
    }

    // ── Contas bancárias ──────────────────────────────────────
    match /contas/{docId} {
      allow read:   if ownFamily();
      allow create: if writingOwnFamily();
      allow update: if ownFamily() && writingOwnFamily();
      allow delete: if ownFamily();
    }

    // ── Categorias ────────────────────────────────────────────
    match /categorias/{docId} {
      allow read:   if ownFamily();
      allow create: if writingOwnFamily();
      allow update: if ownFamily() && writingOwnFamily();
      allow delete: if ownFamily();
    }

    // ── Bloqueio total (qualquer outra coleção) ───────────────
    // O Firestore nega por padrão, mas esta regra é explícita
    // para evitar que futuras coleções sejam acidentalmente abertas.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
